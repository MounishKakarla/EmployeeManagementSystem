{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ems-backend-python.onrender.com/api"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      },
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ems-backend-python.onrender.com/api"
      }
    },
    "production": {
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "distribution": "internal",
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://ems-backend-python.onrender.com/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
