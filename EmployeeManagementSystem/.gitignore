# Dependency directories
**/node_modules/
**/jspm_packages/
**/__pycache__/
**/.venv/
**/venv/
**/env/
**/*.pyc
**/*.pyo
**/*.pyd

# Java/Spring Boot
**/target/
**/*.class
**/*.jar
**/*.war
**/*.ear
**/*.nar
**/.mvn/wrapper/maven-wrapper.jar
**/bin/

# Build output
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/

# IDE files
**/.idea/
**/.vscode/
**/*.swp
**/*.swo
**/*.iml
**/.project
**/.classpath
**/.settings/

# OS files
**/.DS_Store
**/.DS_Store?
**/._*
**/.Spotlight-V100
**/.Trashes
**/ehthumbs.db
**/ehthumbs_vista.db
**/*.stackdump
**/[Tt]humbs.db
**/$RECYCLE.BIN/

# Environment files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/*.properties.local

# Logs
**/logs/
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# Coverage directory used by tools like istanbul
**/coverage/
**/*.lcov

# Other
**/.cache/
**/.eslintcache

# Docker specifics
**/postgres_data/
**/.docker/
**/docker-compose.override.yml

# Expo / Mobile
**/.expo/
**/*.apk
**/*.aab
**/web-build/

